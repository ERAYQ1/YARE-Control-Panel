# ==============================================================================
# YARE Control Panel - .gitignore
# ==============================================================================

# Node.js & Package Managers
node_modules/
.pnpm-store/
.npm/
.node_repl_history
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Build Outputs & Caches
dist/
build/
out/
bin/
coverage/
.vite/
.cache/
.turbo/
.eslintcache
!apps/backend/dist/.gitkeep

# Go Executables & Compiled Binaries
yare-backend
yare-backend.exe
yare-panel
yare-panel.exe
*.exe
*.exe?
*.dll
*.so
*.dylib
*.test
*.out

# YARE SQLite Databases & Runtime Data
yare.db*
*.db
*.db-*
*.sqlite
*.sqlite3
*.db-journal
*.db-shm
*.db-wal
data/
uploads/
backups/
logs/
tmp/
temp/
*.tmp
*.log
*.tar.gz
*.zip

# Environment & Config Files (Allow .env.example)
.env
.env.*
!.env.example

# Secrets, Certificates & Keys
*.pem
*.key
*.crt
*.p12
*.pfx
id_rsa
id_rsa.pub
id_ed25519
id_ed25519.pub
*.secret
secrets.*
credentials.*

# IDE & System Metadata
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
.DS_Store?
Thumbs.db
ehthumbs.db
desktop.ini
