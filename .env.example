# ==============================================================================
# YARE Control Panel - Environment Configuration Template
# Copy this file to '.env' in your production environment and customize values.
# IMPORTANT: DO NOT commit real secrets or passwords to version control!
# ==============================================================================

# Server Network Configuration
# Port on which the YARE backend HTTP & WebSocket server will listen
PORT=8080

# Environment Mode
# Set to 'production' for release performance mode or 'development' for verbose logging
ENV=production

# SQLite Database Storage Location
# Absolute path to the SQLite database file on the server host or container
DB_PATH=/opt/yare/yare.db

# JWT Secret Key
# High-entropy random secret key used to sign and verify JWT authentication tokens (min 32 chars)
# Example generation command: openssl rand -base64 32
JWT_SECRET=replace-with-a-secure-random-32-character-secret-key

# Optional: CORS Allowed Origin
# Restrict API access to specific domain in production (e.g. https://panel.yourdomain.com)
ALLOW_ORIGIN=*
